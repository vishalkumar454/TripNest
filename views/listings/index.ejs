<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TripNest</title>
</head>
<body>
    <h2>All Listings</h2>
    <ul>
        <% allListings.forEach(listings => { %>
            <li><a href="/listings/<%= listings.id %>"><%= listings.title %></a></li>
        <% }) %>
    </ul>
</body>
</html>